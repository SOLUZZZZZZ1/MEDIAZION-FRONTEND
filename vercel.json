{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://backend-api-mediazion-1.onrender.com/api/:path*" },
    { "source": "/suscripcion/:path*", "destination": "/index.html" },
    { "source": "/panel-mediador", "destination": "/index.html" },
    { "source": "/(admin|mediadores)(.*)", "destination": "/index.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
